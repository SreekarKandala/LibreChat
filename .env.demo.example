# Demo environment overrides — copy to `.env.demo` and fill in real values.
# Loaded via `npm run start:demo` (node --env-file). Values set here take
# precedence over `.env`, which is still loaded for shared settings.

MONGO_URI=

# Login has been removed: every request runs as this user (the API is
# open to anyone who can reach it — keep it network-isolated).
SERVICE_USER_EMAIL=

DOMAIN_CLIENT=
DOMAIN_SERVER=

# Per-environment secrets — never reuse across environments.
# Generate at https://www.librechat.ai/toolkit/creds_generator
JWT_SECRET=
JWT_REFRESH_SECRET=
CREDS_KEY=
CREDS_IV=
