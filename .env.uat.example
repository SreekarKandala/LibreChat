# UAT environment overrides — copy to `.env.uat` and fill in real values.
# Loaded via `npm run start:uat` (node --env-file). Values set here take
# precedence over `.env`, which is still loaded for shared settings.

MONGO_URI=

DOMAIN_CLIENT=
DOMAIN_SERVER=

# Per-environment secrets — never reuse across environments.
# Generate at https://www.librechat.ai/toolkit/creds_generator
JWT_SECRET=
JWT_REFRESH_SECRET=
CREDS_KEY=
CREDS_IV=
