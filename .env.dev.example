# Dev environment overrides — copy to `.env.dev` and fill in real values.
# Loaded via `npm run start:dev` (node --env-file). Values set here take
# precedence over `.env`, which is still loaded for shared settings.

MONGO_URI=mongodb://127.0.0.1:27017/LibreChat-dev

# Act as this user for every request without requiring login (the API is
# then open to anyone who can reach it — keep it network-isolated).
NO_AUTH=true
NO_AUTH_USER_EMAIL=

DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

# Per-environment secrets — never reuse across environments.
# Generate at https://www.librechat.ai/toolkit/creds_generator
JWT_SECRET=
JWT_REFRESH_SECRET=
CREDS_KEY=
CREDS_IV=
